ame":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"条件","name":"CONDITIONING","type":"CONDITIONING","links":[]}],"title":"Negative Prompt","properties":{"cnr_id":"comfy-core","ver":"0.10.0","Node name for S&R":"CLIPTextEncode","ue_properties":{"version":"7.0.1","widget_ue_connectable":{"text":true}}},"widgets_values":["low query, blur, illustration style, bad anatomy, bad hands, missing fingers, extra fingers, three hands, three legs, bad arms, missing legs, missing arms, poorly drawn face, bad face, fused face, cloned face, three crus, fused feet, fused thigh, extra crus, ugly fingers, horn, cartoon, cg, 3d, unreal, animate, amputation, disconnected limbs"],"color":"#322","bgcolor":"#533"},{"id":7,"type":"CLIPTextEncode","pos":[3548.161686908595,405.128456381962],"size":[390.50470025405684,377.24559525760185],"flags":{},"order":6,"mode":0,"inputs":[{"localized_name":"clip","name":"clip","type":"CLIP","link":3},{"localized_name":"文本","name":"text","type":"STRING","widget":{"name":"text"},"link":null}],"outputs":[{"localized_name":"条件","name":"CONDITIONING","type":"CONDITIONING","links":[6,115,209]}],"title":"Postive Prompt","properties":{"cnr_id":"comfy-core","ver":"0.10.0","Node name for S&R":"CLIPTextEncode","ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":["这是一张日常随手拍的生活照片，画面聚焦在一只年轻女性的右手，她的手指纤细白皙，指甲修剪整齐，正握着一个橙红色调的塑料杯装饮料——Meco如鲜果茶（香橙味）。杯身是经典的圆柱形塑料杯，杯壁印着鲜艳的红色主色调，上面有醒目的“Meco”logo和卡通化的五位年轻男偶像（疑似某男团成员）合照，他们穿着鲜艳的校服或休闲装，笑容灿烂，充满青春活力。杯子顶部盖着黑色塑料盖，插着吸管，杯身中部有“香橙果茶”几个大字，下面标注“港版”或类似小字，杯底有橙色果汁残留和气泡痕迹，看起来刚喝过几口。\n背景是超市货架，货架上摆满了各种饮料：绿茶、乌龙茶、果汁瓶等，五颜六色，灯光从上方洒下，在杯身和货架上投下柔和反光。整个色调温暖明亮，橙红色的杯子成为视觉焦点，传递出一种逛超市买饮料的轻松日常感，带着年轻女孩随手记录生活的可爱与随意。照片边缘略带手抖模糊，真实接地气，像小红书或朋友圈常见的分享瞬间。\nA Dark artistic logo in the upper center of the screen that reads'DarkBeastZ Blitz6 FP32' , 右下角精致极小字体标注“based on BEYOND REALITY3 超越真实3”"],"color":"#adff14","bgcolor":"#99ff00","shape":1},{"id":81,"type":"UNETLoader","pos":[1360.2855857427696,537.4